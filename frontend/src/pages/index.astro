---
// index.astro — Shell page.
// `client:load` hydrates SmartOrder immediately on page load (React island).
// All business logic stays in the React layer; Astro only provides the HTML shell.
import SmartOrder from '../components/SmartOrder';
import '../styles/global.css';
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Smart Order AI — Ingesta de pedidos B2B potenciada por Groq" />
    <title>Smart Order AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="min-h-screen md:h-screen flex flex-col md:overflow-hidden font-sans antialiased text-gray-900 bg-gray-50">
    <header class="flex items-center gap-4 px-6 py-4 bg-white border-b border-gray-200 shrink-0 sticky top-0 z-50 shadow-sm">
      <div class="flex items-center gap-1 text-lg font-extrabold tracking-tight text-gray-900">
        Smart<span class="text-blue-600">Order</span><span class="text-gray-300 font-light ml-1">AI</span>
      </div>
      <div class="text-[10px] font-bold tracking-widest text-emerald-600 bg-emerald-50 border border-emerald-100 rounded-full px-3 py-1 uppercase shadow-inner">
        MVP · Potenciado por Groq
      </div>
    </header>

    <main class="flex-1 min-h-0">
      <SmartOrder client:load />
    </main>
  </body>
</html>
