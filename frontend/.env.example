# ─────────────────────────────────────────────
# Smart Order AI — Frontend Environment
# ─────────────────────────────────────────────

# URL of the backend API.
# In development: points to local Spring Boot via docker-compose.
# In production: replace with the ngrok URL before running `astro build`.
PUBLIC_API_URL=http://localhost:8080

# API key sent as X-API-Key header on every request.
# Must match API_KEY in the root .env.
PUBLIC_API_KEY=so_sk_your_secret_api_key_here
