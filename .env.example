# ─────────────────────────────────────────────────────────────
# Smart Order AI — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────
DB_NAME=smartorder
DB_USERNAME=smartorder
DB_PASSWORD=smartorder_secret

# ── Groq AI ─────────────────────────────────
GROQ_API_KEY=gsk_your_actual_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── CORS ─────────────────────────────────────
# En local: dejar en * (o vacío para usar el default)
# En producción: poner el dominio de Hostinger exacto
# CORS_ALLOWED_ORIGINS=https://tudominio.hostinger.com

# ── API Key ───────────────────────────────────
# Generate with: openssl rand -base64 32
# Must match PUBLIC_API_KEY in frontend/.env
API_KEY=so_sk_your_secret_api_key_here
